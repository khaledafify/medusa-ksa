{
  "$schema": "https://unpkg.com/syncpack@13.0.4/dist/schema.json",
  "versionGroups": [
    {
      "label": "Connectors depend on core via the workspace protocol; Changesets rewrites it to a real range on publish (docs/CONFIGURATION.md §1)",
      "dependencies": ["@medusa-ksa/core"],
      "dependencyTypes": ["prod"],
      "packages": ["**"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "The demo-store app (unpublished) consumes suite packages via the workspace protocol",
      "dependencies": ["@medusa-ksa/*", "medusa-payment-*", "medusa-fulfillment-*", "medusa-notification-*", "medusa-plugin-*"],
      "dependencyTypes": ["prod"],
      "packages": ["demo-store"],
      "pinVersion": "workspace:*"
    }
  ],
  "semverGroups": [
    {
      "label": "Use caret ranges everywhere (one shared policy across the suite)",
      "range": "^",
      "dependencies": ["**"],
      "dependencyTypes": ["prod", "dev", "peer"],
      "packages": ["**"]
    }
  ],
  "sortFirst": ["name", "version", "private", "description", "license", "author"],
  "sortPackages": true
}
