# Copy to .env and fill in. Sandbox/live is auto-detected from the key prefix.
MOYASAR_SECRET_KEY=sk_test_your-key-here
MOYASAR_PUBLISHABLE_KEY=          # optional — only for embedded Moyasar.js
MOYASAR_WEBHOOK_SECRET=           # optional, recommended in production

DATABASE_URL=postgres://user@localhost:5432/medusa_demo
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
COOKIE_SECRET=change-me

STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:9000,http://localhost:7001,http://localhost:8000
