{
  "name": "medusa-ksa",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source toolkit for running Saudi e-commerce on Medusa v2 — payments, ZATCA e-invoicing, local fulfillment, and Arabic notifications.",
  "license": "MIT",
  "author": "Khaled Afify and contributors",
  "bugs": "https://github.com/khaledafify/medusa-ksa/issues",
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.18.0",
    "@medusajs/test-utils": "^2.13.0",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "syncpack": "^13.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "homepage": "https://github.com/khaledafify/medusa-ksa#readme",
  "packageManager": "pnpm@9.15.4",
  "repository": "khaledafify/medusa-ksa.git",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "dev": "turbo run dev --filter=demo-store",
    "format": "prettier --write .",
    "lint": "turbo run lint && depcruise packages && syncpack lint",
    "release": "changeset publish",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version"
  },
  "type": "module"
}
