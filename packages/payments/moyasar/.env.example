# Moyasar secret key (REQUIRED) — copy from the Moyasar Dashboard →
# Settings → API Keys (https://dashboard.moyasar.com). Sandbox vs live is
# auto-detected from the key prefix (sk_test_… vs sk_live_…) — no mode flag.
MOYASAR_SECRET_KEY=sk_test_your-key-here

# Publishable key (OPTIONAL) — only needed if your storefront embeds
# Moyasar.js to tokenize a source. The hosted-redirect default works on the
# secret key alone.
MOYASAR_PUBLISHABLE_KEY=

# Webhook shared secret — the same value you enter when registering the
# webhook endpoint in the Moyasar Dashboard → Settings → Webhooks.
# Optional, but strongly recommended in production.
MOYASAR_WEBHOOK_SECRET=
