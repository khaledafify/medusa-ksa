{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": ".medusa/server",
    "rootDir": ".",
    // This package compiles to CommonJS (no "type": "module"): Medusa's
    // plugin tooling (plugin:db:generate) require()s raw .ts sources, which
    // is impossible in an ESM-typed package. verbatimModuleSyntax forbids
    // `import` syntax in CJS emit, so it is relaxed here only.
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx"
  },
  "include": ["src", "scripts", "vitest.config.ts"],
  // src/admin is browser code (DOM lib) — typechecked via tsconfig.admin.json
  // to keep the DOM types away from the server's xmldom typings.
  "exclude": [".medusa", "node_modules", "src/admin"]
}
