# ZATCA environment: sandbox | simulation | production
ZATCA_ENV=sandbox

# 32-byte base64 key for encrypting EGS credentials at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
ZATCA_ENCRYPTION_KEY=

# When to issue the invoice: payment_captured (default) | order_placed
ZATCA_TRIGGER=payment_captured
